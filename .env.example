# Copiar a .env.local y completar los valores
# .env.local es ignorado por git

# URL del Worker backend (vacío = usar proxy de Vite en dev)
VITE_API_URL=

# Nombre del evento que aparece en el header del menú
VITE_EVENT_NAME=Cumpleaños de [nombre]

# Nivel de logging: debug | info | warn | error
# Default: debug en dev, info en prod
VITE_LOG_LEVEL=debug
